# VIBRANIUM AI Environment Variables

# Groq LLM inference
# Get API key from https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Best fit default for strategic analysis quality
GROQ_MODEL=llama-3.3-70b-versatile

# API Configuration (optional)
API_HOST=0.0.0.0
API_PORT=8000

# Logging Level (optional)
LOG_LEVEL=INFO

# Reddit API (https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=vibranium-ai-collector/1.0

# Product Hunt GraphQL token
PRODUCTHUNT_ACCESS_TOKEN=

# Google Sheets destination
GOOGLE_SHEET_ID=
GOOGLE_SHEET_WORKSHEET=reviews

# Provide one of the following for Sheets auth:
# GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/service-account.json
GOOGLE_SERVICE_ACCOUNT_FILE=
# GOOGLE_SERVICE_ACCOUNT_JSON={...json...}
GOOGLE_SERVICE_ACCOUNT_JSON=

# Daily scheduler (UTC)
DAILY_COLLECT_HOUR=3
DAILY_COLLECT_MINUTE=0
# Comma-separated products for auto-collection job
DAILY_COLLECT_PRODUCTS=Notion,Slack,Figma

# NLP runs in lexical/rule mode; no heavyweight model downloads required.
