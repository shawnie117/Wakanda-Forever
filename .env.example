# Frontend env vars (Vite)
# Copy this file to .env in project root and fill your actual values.

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend base URL used by src/services/aiApi.js
# Local:  http://127.0.0.1:8000/api/v1
# HF:     https://shawniii-vibranium-ai.hf.space/api/v1
# If omitted, frontend uses relative /api/v1 (works with Vite proxy or same-origin deploy)
VITE_AI_API_URL=
